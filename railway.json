{
  "build": {
    "builder": "NIXPACKS",
    "commands": [
        "cp .env.prod .env",
        "composer install --no-dev --optimize-autoloader",
        "cd frontend && npm install && npm run build && rm -rf ../public/assets ../public/index.html ../public/*.js ../public/*.css && cp -r dist/* ../public/",
        "mkdir -p config/jwt",
        "openssl genpkey -out config/jwt/private.pem -algorithm RSA -pkeyopt rsa_keygen_bits:4096",
        "openssl pkey -in config/jwt/private.pem -out config/jwt/public.pem -pubout",
        "chmod 600 config/jwt/private.pem && chmod 644 config/jwt/public.pem"
    ]
  },
  "deploy": {
    "startCommand": "php -S 0.0.0.0:8080 -t public"
  }
}
